{
  "compilerOptions": {
    "outDir": "dist/main",
    "allowSyntheticDefaultImports": true,
    "module": "nodenext",
    "target": "esnext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "alwaysStrict": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "jsx": "react-jsx"
  }
}
